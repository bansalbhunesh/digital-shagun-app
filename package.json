{
  "name": "workspace",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "test": "pnpm -r --if-present run test",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --if-present run typecheck",
    "prepare": "husky",
    "format": "prettier --write .",
    "lint": "eslint ."
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "pnpm run typecheck",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "private": true,
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "eslint": "^9.21.0",
    "eslint-plugin-security": "^3.0.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "@replit/connectors-sdk": "^0.3.0",
    "pino-http": "^11.0.0"
  }
}
